              <p class="text-sm text-zinc-400" data-ps="src/components/home/Pricing.astro:hp3fw">Secures your project on our calendar.</p>
            </div>
          </div>
          <div class="flex items-center gap-4 py-4 border-b border-zinc-800" data-ps="src/components/home/Pricing.astro:xj797p">
            <div class="w-10 h-10 rounded-full bg-indigo-600/20 flex items-center justify-center text-indigo-500 shrink-0" data-ps="src/components/home/Pricing.astro:xj797o">
