---
import { SITE } from '@/config/site';
---

<footer class="bg-zinc-950 text-white py-20 px-6 border-t border-zinc-900" data-ps="src/components/Footer.astro:ikmf32">
  <div class="max-w-7xl mx-auto" data-ps="src/components/Footer.astro:p4vf87">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16" data-ps="src/components/Footer.astro:p4vf88">
      <!-- Company Info -->
      <div class="lg:col-span-2" data-ps="src/components/Footer.astro:p4vf89">
        <a href="/" class="text-xl font-bold tracking-tight text-white no-underline flex items-center gap-2 mb-6" data-ps="src/components/Footer.astro:f-logo">
          <span class="w-8 h-8 bg-indigo-600 rounded flex items-center justify-center text-sm" data-ps="src/components/Footer.astro:hzwfpc">GW</span>
          {SITE.name}
        </a>
        <p class="text-zinc-400 max-w-sm mb-8 leading-relaxed" data-ps="src/components/Footer.astro:euok">
          {SITE.description} We believe high-end design should be accessible to every business.
        </p>
        <div class="flex gap-4" data-ps="src/components/Footer.astro:p4vf8b">
          <a href={SITE.socials.twitter} class="p-2 bg-zinc-900 rounded-full text-zinc-400 hover:text-white transition-colors" aria-label="Twitter" data-ps="src/components/Footer.astro:8o2pf">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
          <a href={SITE.socials.instagram} class="p-2 bg-zinc-900 rounded-full text-zinc-400 hover:text-white transition-colors" aria-label="Instagram" data-ps="src/components/Footer.astro:8o2pg">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.246 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.332 2.633-1.308 3.608-.975.975-2.242 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.332-3.608-1.308-.975-.975-1.246-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.246 3.608-1.308 1.266-.058 1.646-.07 4.85-.07M12 0C8.741 0 8.333.014 7.053.072 2.695.272.272 2.69.072 7.053.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.2 4.353 2.62 6.777 6.98 6.977 1.28.057 1.688.072 4.948.072s3.667-.015 4.947-.072c4.351-.2 6.777-2.62 6.977-6.977.058-1.28.072-1.688.072-4.947s-.015-3.667-.072-4.947c-.2-4.353-2.62-6.777-6.977-6.977C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div data-ps="src/components/Footer.astro:p4vf8a">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-6" data-ps="src/components/Footer.astro:f0091f">Navigation</h2>
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          <li data-ps="src/components/Footer.astro:wyji7b"><a href="/#process" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0j">Our Process</a></li>
          <li data-ps="src/components/Footer.astro:wyji7c"><a href="/#guarantee" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0k">Guarantee</a></li>
          <li data-ps="src/components/Footer.astro:wyji7d"><a href="/#pricing" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l">Pricing</a></li>
          <li data-ps="src/components/Footer.astro:wyji7e"><a href="/#contact" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0m">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div data-ps="src/components/Footer.astro:p4vf8c">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-6" data-ps="src/components/Footer.astro:f0091a">Support</h2>
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          <li data-ps="src/components/Footer.astro:wyji7h"><a href="mailto:gokeywebsites@gmail.com" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2ph">Support Email</a></li>
          <li data-ps="src/components/Footer.astro:wyji7i"><a href="#" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pi">Privacy Policy</a></li>
          <li data-ps="src/components/Footer.astro:sq28di"><a href="#" class="text-zinc-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pj">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-zinc-900 pt-12 flex flex-col md:flex-row justify-between items-center gap-6" data-ps="src/components/Footer.astro:p4vf8b">
      <p class="text-sm text-zinc-500" data-ps="src/components/Footer.astro:euol">© {new Date().getFullYear()} {SITE.name}. Designing the future for small business.</p>
      <p class="text-sm text-zinc-400" data-ps="src/components/Footer.astro:euor">Built with precision in Jacksonville, FL.</p>
    </div>
  </div>
</footer>
